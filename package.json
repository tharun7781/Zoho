{
  "name": "teams-zoho-bot",
  "version": "1.0.0",
  "description": "Microsoft Teams + Zoho Projects Integration Assistant — powered by Groq LLM & Adaptive Cards",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "dashboard": "node dist/dashboard/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts"
  },
  "keywords": ["microsoft-teams", "bot", "zoho", "adaptive-cards", "groq"],
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.7",
    "botbuilder": "^4.21.3",
    "botbuilder-dialogs": "^4.21.3",
    "botframework-connector": "^4.21.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "groq-sdk": "^0.3.3",
    "node-cache": "^5.1.2",
    "uuid": "^9.0.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.19",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^7.1.0",
    "@typescript-eslint/parser": "^7.1.0",
    "eslint": "^8.57.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  },
  "engines": { "node": ">=20.0.0" }
}
